{
  "name": "@morph/web",
  "version": "0.1.0",
  "private": true,
  "description": "MORPH - a personal accessibility runtime for the living web.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "dev:portal": "npm run dev --workspace @morph/demo-portal",
    "start": "vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit && npm run typecheck --workspaces --if-present",
    "build:workspaces": "npm run build --workspaces --if-present",
    "build:all": "npm run build:workspaces && npm run build",
    "test:workspaces": "npm test --workspaces --if-present",
    "eval": "npm run eval --workspace @morph/evals",
    "health": "npm run health --workspaces --if-present",
    "check": "npm run lint && npm run typecheck && npm run eval && npm run test:workspaces && npm test",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "overrides": {
    "ws": "8.21.0",
    "postcss": "8.5.19"
  }
}
