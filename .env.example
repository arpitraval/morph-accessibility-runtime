# OpenAI runtime (wired in Phase 4)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
MORPH_MULTI_AGENT_ENABLED=false

# Durable state (wired in Phase 2)
DATABASE_URL=

# Safe demo defaults
MORPH_DEMO_MODE=replay
MORPH_MAX_REPLANS=3
MORPH_REQUIRE_CONSENT=true
NEXT_PUBLIC_DEMO_PORTAL_URL=http://127.0.0.1:4173
CODEX_ADAPTER_FORGE_ENABLED=false
CODEX_API_KEY=
CODEX_ADAPTER_MODEL=gpt-5.6-sol
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MORPH_ADAPTER_SIGNING_PRIVATE_KEY_PEM=
MORPH_ADAPTER_SIGNING_KEY_ID=local-dev-v1
MORPH_ADAPTER_FORGE_ROOT=.morph-forge

# Local service ports
ORCHESTRATOR_PORT=8788
BROWSER_WORKER_PORT=8790
ADAPTER_FORGE_PORT=8792

# Agent Observatory: "live" uses authenticated SSE; "replay" is the labeled judge fallback.
NEXT_PUBLIC_MORPH_OBSERVATORY_MODE=replay
NEXT_PUBLIC_ORCHESTRATOR_SSE_URL=http://127.0.0.1:8788/v1/sessions/{sessionId}/events
NEXT_PUBLIC_ORCHESTRATOR_MUTATION_URL=http://127.0.0.1:8788/v1/demo/sessions/{sessionId}/mutate
MORPH_WEB_ORIGIN=http://127.0.0.1:3000
MORPH_DEMO_SESSION_ID=10000000-0000-4000-8000-000000000001
MORPH_STREAM_AUTH_TOKEN=