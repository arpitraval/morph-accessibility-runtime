{
  "name": "@morph/browser-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "health": "npm run build --silent && node dist/index.js --health",
    "test": "npm run build --workspace @morph/demo-portal --silent && npm run build --silent && node --test dist/index.test.js dist/worker.integration.test.js"
  },
  "dependencies": {
    "@morph/agents": "^0.1.0",
    "@morph/contracts": "^0.1.0",
    "@morph/state-machine": "^0.1.0",
    "playwright": "^1.61.1"
  }
}
