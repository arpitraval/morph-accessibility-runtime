{
  "name": "@morph/adapter-forge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "health": "npm run build --silent && node dist/index.js --health",
    "test": "npm run build --silent && node --test --test-isolation=none dist/*.test.js"
  },
  "dependencies": {
    "@morph/contracts": "0.1.0",
    "@openai/codex-sdk": "0.144.4",
    "axe-core": "4.12.1",
    "drizzle-orm": "0.45.2",
    "openai": "6.46.0",
    "pg": "8.22.0",
    "playwright": "1.61.1",
    "sanitize-html": "2.17.0",
    "typescript": "5.9.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "@types/sanitize-html": "2.16.0"
  }
}
